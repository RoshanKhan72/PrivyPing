<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

<!-- ✅ REQUIRED for Android 13+ notifications -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="PrivyPing"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.PrivyPing"
        android:networkSecurityConfig="@xml/network_security_config"
        android:usesCleartextTraffic="true">

<activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"

            android:theme="@style/Theme.PrivyPing.Splash">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- NOTIFICATION LISTENER SERVICE -->
        <service
            android:name=".service.PrivyNotificationListener"
            android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE"
android:exported="false">
            <intent-filter>
                <action android:name="android.service.notification.NotificationListenerService" />
            </intent-filter>
        </service>

        <!-- MULTIMEDIA ACTIVITY (CRASH FIXED) -->
        <activity
            android:name="com.swavik.privyping.multimedia.MultimediaActivity"
            android:exported="false"
            android:label="Multimedia Analysis"
            android:parentActivityName=".MainActivity"
            android:theme="@style/Theme.PrivyPing" />

        <!-- VIDEO ANALYSIS ACTIVITY -->
        <activity
            android:name="com.swavik.privyping.multimedia.BetterVideoActivity"
            android:exported="false"
            android:label="Advanced Video AI Analysis"
            android:parentActivityName=".MainActivity"
            android:theme="@style/Theme.PrivyPing" />





    </application>

</manifest>
